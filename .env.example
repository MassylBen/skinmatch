# SkinMatch — Variables d'environnement
# Copier ce fichier en .env.local et remplir les valeurs
# NE JAMAIS committer .env.local dans git

# ── Supabase ──────────────────────────────────────────────────────────────────
# Trouvables dans: Supabase Dashboard → Settings → API
SKINMATCH_SUPABASE_URL=https://VOTRE_PROJECT_ID.supabase.co
SKINMATCH_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Debug (développement uniquement) ─────────────────────────────────────────
# Mettre à "true" pour activer console.log dans auth.js et db.js
SKINMATCH_DEBUG=false
